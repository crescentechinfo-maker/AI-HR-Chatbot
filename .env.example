# ============================================================
# HR Chatbot — Environment Variables
# Copy this file to .env.local for local development
# ============================================================

# ── AI / OpenRouter ────────────────────────────────────────
# Get your API key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Default model (can be changed in Admin → Settings)
# Examples: openai/gpt-4o-mini  |  openai/gpt-4o  |  mistralai/mistral-7b-instruct
AI_MODEL=google/gemma-4-31b-it

# ── Admin Panel ───────────────────────────────────────────
# Password to access /admin (change before deploying!)
ADMIN_PASSWORD=change-me-before-deploying

# Secret key for signing JWT tokens (use a long random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ── App ───────────────────────────────────────────────────
# Public URL (used for OpenRouter HTTP-Referer header)
NEXT_PUBLIC_APP_URL=http://localhost:3000
